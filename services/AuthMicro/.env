# бд
POSTGRES_DB_HOST=auth-db-postgres
POSTGRES_DB=auth_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_auth_password
POSTGRES_DB_INTERNAL_PORT=5432
POSTGRES_DB_EXTERNAL_PORT=5432

# Порт сервиса
AUTH_HTTP=8081

# JWT и безопасность
JWT_SECRET=rZvFZnkPmXr8Cd4FB9qp7bTMEnsvzKRJlOcp1piMHtA=
ACCESS_TOKEN_LIFETIME=900000
REFRESH_TOKEN_LIFETIME=604800000

# Коды подтверждения
CODE_LIFETIME_MINUTES=15
ACTUAL_CODE_PATTERN=^[0-9]{6}$

# Почта 
ENV_USERNAME=example@mail.ru
ENV_PASSWORD=our_app_password
MAIL_HOST=smtp.mail.ru
MAIL_PORT=465

# Swagger / Документация
ENV_SWAGGER_API_VERSION_AUTH=1.0
ENV_SWAGGER_APP_DESCRIPTION_AUTH=Auth Service API
ENV_SWAGGER_LICENSE=Apache 2.0
ENV_SWAGGER_LICENSE_URL=https://apache.org
ENV_SWAGGER_DEV_SERVER_AUTH=http://localhost:8081

# Docker Healthcheck (чтобы не было ошибок в docker-compose)
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3

# Очистка сессий 
CODE_CLEAN_TIME=60000
REGISTRATION_LOGIN_SESSION_CLEAN_TIME=60000
REGISTRATION_LOGIN_SESSION_LIFETIME=30
REFRESH_TOKEN_SESSION_CLEAN_TIME=60000
